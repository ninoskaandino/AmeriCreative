# ==========================================
# AMERIDENT CREATIVE STUDIO ENV CONFIGURATION
# ==========================================

# Port the backend Express API will listen on
PORT=5000

# JSON Web Token encryption secret (any secure random string)
JWT_SECRET=amerident-creative-studio-super-secret-key-12345

# Fallback Demo Mode: Set to 'true' to simulate Amazon Bedrock calls without AWS credentials.
# Set to 'false' to enable direct calls to real AWS Bedrock APIs.
DEMO_MODE=true

# AWS Credentials for Amazon Bedrock (Only needed when DEMO_MODE=false)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_SESSION_TOKEN=YOUR_AWS_SESSION_TOKEN_IF_NEEDED

# Foundation models used on AWS Bedrock
BEDROCK_TEXT_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_IMAGE_MODEL=stability.stable-diffusion-xl-v1
